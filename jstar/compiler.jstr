        divide it 65536
        store it into text at text_len
        add text_len 1
        store it into text_len
        bitand op_val 0xFF000000
        divide it 16777216
        store it into text at text_len
        add text_len 1
        store it into text_len

        # syscall
        store 0x0F into text at text_len
        add text_len 1
        store it into text_len
        store 0x05 into text at text_len
        add text_len 1
        store it into text_len

        # Consume num + 3 args. Loop epilogue adds one more.
        add tok_idx 4
        store it into tok_idx

        # Keep old generic handler disabled for deterministic bootstrap.
        if equal 1 0
        # Strategy: load all args into target registers first, then syscall number last.
        # This avoids "it" clobbering since rax is loaded last.
        # Count args by peeking ahead.

        # Count operands: unrolled, no loops, no else.
        # sc_argc counts consecutive operand tokens after syscall keyword.
        # An operand is type 50 (literal), 52 (variable), or 22 (it/that).
        # "active" flag (temp3): 1 = still counting, 0 = stopped.
        store 0 into sc_argc
        store 1 into temp3
        add tok_idx 1
        store it into temp2
        # Position 1
        if compare temp3 0
            if compare temp2 tok_count
                load from tok_type at temp2
                store it into temp4
                store 0 into k
                if equal temp4 50
                    store 1 into k
                end
                if equal temp4 52
                    store 1 into k
                end
                if equal temp4 22
                    store 1 into k
                end
                if compare k 0
                    add sc_argc 1
                    store it into sc_argc
                    add temp2 1
                    store it into temp2
                end
                if equal k 0
                    store 0 into temp3
                end
            end
        end
        # Position 2
        if compare temp3 0
            if compare temp2 tok_count
                load from tok_type at temp2
                store it into temp4
                store 0 into k
                if equal temp4 50
                    store 1 into k
                end
                if equal temp4 52
                    store 1 into k
                end
                if equal temp4 22
                    store 1 into k
                end
                if compare k 0
                    add sc_argc 1
                    store it into sc_argc
                    add temp2 1
                    store it into temp2
                end
                if equal k 0
                    store 0 into temp3
                end
            end
        end
        # Position 3
        if compare temp3 0
            if compare temp2 tok_count
                load from tok_type at temp2
                store it into temp4
                store 0 into k
                if equal temp4 50
                    store 1 into k
                end
                if equal temp4 52
                    store 1 into k
                end
                if equal temp4 22
                    store 1 into k
                end
                if compare k 0
                    add sc_argc 1
                    store it into sc_argc
                    add temp2 1
                    store it into temp2
                end
                if equal k 0
                    store 0 into temp3
                end
            end
        end
        # Position 4
        if compare temp3 0
            if compare temp2 tok_count
                load from tok_type at temp2
                store it into temp4
                store 0 into k
                if equal temp4 50
                    store 1 into k
                end
                if equal temp4 52
                    store 1 into k
                end
                if equal temp4 22
                    store 1 into k
                end
                if compare k 0
                    add sc_argc 1
                    store it into sc_argc
                    add temp2 1
                    store it into temp2
                end
                if equal k 0
                    store 0 into temp3
                end
            end
        end
        # Position 5
        if compare temp3 0
            if compare temp2 tok_count
                load from tok_type at temp2
                store it into temp4
                store 0 into k
                if equal temp4 50
                    store 1 into k
                end
                if equal temp4 52
                    store 1 into k
                end
                if equal temp4 22
                    store 1 into k
                end
                if compare k 0
                    add sc_argc 1
                    store it into sc_argc
                    add temp2 1
                    store it into temp2
                end
                if equal k 0
                    store 0 into temp3
                end
            end
        end

        # Advance to syscall number operand
        add tok_idx 1
        store it into tok_idx

        # If sc_argc >= 2, load arg1 into rdi
        if greater sc_argc 1
            add tok_idx 1
            store it into temp2
            load from tok_type at temp2
            store it into op_type
            store 0 into op_val
            store 0 into op_off
            if equal op_type 50
                load from tok_value at temp2
                store it into op_val
                store 0 into op_type
            end
            if equal op_type 22
                store 1 into op_type
            end
            if equal op_type 52
                store 2 into op_type
                load from tok_start at temp2
                store it into lookup_src
                load from tok_len at temp2
                store it into lookup_len
                store 0 into lookup_i
                subtract 0 1
                store it into lookup_result
                while compare lookup_i var_count
                    load from var_name_len at lookup_i
                    store it into lookup_cmp_len
                    if equal lookup_len lookup_cmp_len
                        load from var_name_start at lookup_i
                        store it into lookup_cmp_start
                        store 1 into lookup_match
                        store 0 into lookup_j
                        while compare lookup_j lookup_len
                            add lookup_src lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_a
                            add lookup_cmp_start lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_b
                            if compare lookup_a lookup_b
                                store 0 into lookup_match
                            end
                            add lookup_j 1
                            store it into lookup_j
                        end
                        if compare lookup_match 0
                            store lookup_i into lookup_result
                        end
                    end
                    add lookup_i 1
                    store it into lookup_i
                end
                load from var_offset at lookup_result
                store it into op_off
            end
            # Emit: load into rdi
            if equal op_type 0
                # mov edi, imm32: 0xBF + imm32
                store 0xBF into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 1
                # mov rdi, rax: 0x48 0x89 0xC7
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x89 into text at text_len
                add text_len 1
                store it into text_len
                store 0xC7 into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 2
                # mov rdi, [rbp+off]: 0x48 0x8B 0xBD + disp32
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x8B into text at text_len
                add text_len 1
                store it into text_len
                store 0xBD into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            store temp2 into tok_idx
        end

        # If sc_argc >= 3, load arg2 into rsi
        if greater sc_argc 2
            add tok_idx 1
            store it into temp2
            load from tok_type at temp2
            store it into op_type
            store 0 into op_val
            store 0 into op_off
            if equal op_type 50
                load from tok_value at temp2
                store it into op_val
                store 0 into op_type
            end
            if equal op_type 22
                store 1 into op_type
            end
            if equal op_type 52
                store 2 into op_type
                load from tok_start at temp2
                store it into lookup_src
                load from tok_len at temp2
                store it into lookup_len
                store 0 into lookup_i
                subtract 0 1
                store it into lookup_result
                while compare lookup_i var_count
                    load from var_name_len at lookup_i
                    store it into lookup_cmp_len
                    if equal lookup_len lookup_cmp_len
                        load from var_name_start at lookup_i
                        store it into lookup_cmp_start
                        store 1 into lookup_match
                        store 0 into lookup_j
                        while compare lookup_j lookup_len
                            add lookup_src lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_a
                            add lookup_cmp_start lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_b
                            if compare lookup_a lookup_b
                                store 0 into lookup_match
                            end
                            add lookup_j 1
                            store it into lookup_j
                        end
                        if compare lookup_match 0
                            store lookup_i into lookup_result
                        end
                    end
                    add lookup_i 1
                    store it into lookup_i
                end
                load from var_offset at lookup_result
                store it into op_off
            end
            # Emit: load into rsi
            if equal op_type 0
                # mov esi, imm32: 0xBE + imm32
                store 0xBE into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 1
                # mov rsi, rax: 0x48 0x89 0xC6
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x89 into text at text_len
                add text_len 1
                store it into text_len
                store 0xC6 into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 2
                # mov rsi, [rbp+off]: 0x48 0x8B 0xB5 + disp32
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x8B into text at text_len
                add text_len 1
                store it into text_len
                store 0xB5 into text at text_len
                # Save position for post-patching verification
                store text_len into rsi_check_pos
                add text_len 1
                store it into text_len
                bitand op_off 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            store temp2 into tok_idx
        end

        # If sc_argc >= 4, load arg3 into rdx
        if greater sc_argc 3
            add tok_idx 1
            store it into temp2
            load from tok_type at temp2
            store it into op_type
            store 0 into op_val
            store 0 into op_off
            if equal op_type 50
                load from tok_value at temp2
                store it into op_val
                store 0 into op_type
            end
            if equal op_type 22
                store 1 into op_type
            end
            if equal op_type 52
                store 2 into op_type
                load from tok_start at temp2
                store it into lookup_src
                load from tok_len at temp2
                store it into lookup_len
                store 0 into lookup_i
                subtract 0 1
                store it into lookup_result
                while compare lookup_i var_count
                    load from var_name_len at lookup_i
                    store it into lookup_cmp_len
                    if equal lookup_len lookup_cmp_len
                        load from var_name_start at lookup_i
                        store it into lookup_cmp_start
                        store 1 into lookup_match
                        store 0 into lookup_j
                        while compare lookup_j lookup_len
                            add lookup_src lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_a
                            add lookup_cmp_start lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_b
                            if compare lookup_a lookup_b
                                store 0 into lookup_match
                            end
                            add lookup_j 1
                            store it into lookup_j
                        end
                        if compare lookup_match 0
                            store lookup_i into lookup_result
                        end
                    end
                    add lookup_i 1
                    store it into lookup_i
                end
                load from var_offset at lookup_result
                store it into op_off
            end
            # Emit: load into rdx
            if equal op_type 0
                # mov edx, imm32: 0xBA + imm32
                store 0xBA into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 1
                # mov rdx, rax: 0x48 0x89 0xC2
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x89 into text at text_len
                add text_len 1
                store it into text_len
                store 0xC2 into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 2
                # mov rdx, [rbp+off]: 0x48 0x8B 0x95 + disp32
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x8B into text at text_len
                add text_len 1
                store it into text_len
                store 0x95 into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            store temp2 into tok_idx
        end

        # Now load syscall number into rax (loaded LAST to avoid "it" clobbering)
        # tok_idx still points at the syscall number token (we saved it before args)
        # Actually, tok_idx was moved when loading args. We need to go back.
        # Wait - we advanced tok_idx past the syscall number to load args.
        # The syscall number is at the original tok_idx+1 position.
        # But we moved tok_idx already. Let me re-think.
        # After "add tok_idx 1" for the syscall number, tok_idx points at N.
        # Then for arg1, we did "add tok_idx 1" and "store temp2 into tok_idx"
        # so tok_idx is now at arg1's position. For arg2 similar.
        # So we need to reload the syscall number from its saved position.
        # Actually, simpler: just go back to the saved position.
        # But wait, we didn't save the syscall number's position.
        # Let me re-think: tok_idx starts at "syscall" keyword.
        # We did "add tok_idx 1" to point to N.
        # Then if sc_argc >= 2, we advanced tok_idx further.
        # After all arg loading, tok_idx points at the last arg.
        # The syscall number N is at original_tok_idx + 1.
        # We can compute it: last_tok_idx - (sc_argc - 1)
        # since args start at original+2 and there are (sc_argc-1) args
        # So N is at tok_idx - (sc_argc - 1)

        subtract sc_argc 1
        store it into temp3
        subtract tok_idx temp3
        store it into temp2
        # temp2 now points at the syscall number token

        load from tok_type at temp2
        store it into op_type
        store 0 into op_val
        store 0 into op_off
        if equal op_type 50
            load from tok_value at temp2
            store it into op_val
            store 0 into op_type
        end
        if equal op_type 22
            store 1 into op_type
        end
        if equal op_type 52
            store 2 into op_type
            load from tok_start at temp2
            store it into lookup_src
            load from tok_len at temp2
            store it into lookup_len
            store 0 into lookup_i
            subtract 0 1
            store it into lookup_result
            while compare lookup_i var_count
                load from var_name_len at lookup_i
                store it into lookup_cmp_len
                if equal lookup_len lookup_cmp_len
                    load from var_name_start at lookup_i
                    store it into lookup_cmp_start
                    store 1 into lookup_match
                    store 0 into lookup_j
                    while compare lookup_j lookup_len
                        add lookup_src lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_a
                        add lookup_cmp_start lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_b
                        if compare lookup_a lookup_b
                            store 0 into lookup_match
                        end
                        add lookup_j 1
                        store it into lookup_j
                    end
                    if compare lookup_match 0
                        store lookup_i into lookup_result
                    end
                end
                add lookup_i 1
                store it into lookup_i
            end
            load from var_offset at lookup_result
            store it into op_off
        end

        # Emit: load syscall number into rax
        if equal op_type 0
            # mov eax, imm32: 0xB8 + imm32
            store 0xB8 into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        end
        if equal op_type 1
            # "it" -- rax already has the value, nop
        end
        if equal op_type 2
            # mov rax, [rbp+off]: 0x48 0x8B 0x85 + disp32
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x8B into text at text_len
            add text_len 1
            store it into text_len
            store 0x85 into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        end

        # Emit: syscall = 0x0F 0x05
        store 0x0F into text at text_len
        add text_len 1
        store it into text_len
        store 0x05 into text at text_len
        add text_len 1
        store it into text_len
        end
    end

    # ── Halt/exit: halt(31) ───────────────────────────────
    if equal temp 31
        # mov edi, 0: 0xBF 0x00 0x00 0x00 0x00
        store 0xBF into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len

        # mov eax, 60: 0xB8 0x3C 0x00 0x00 0x00
        store 0xB8 into text at text_len
        add text_len 1
        store it into text_len
        store 0x3C into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len

        # syscall: 0x0F 0x05
        store 0x0F into text at text_len
        add text_len 1
        store it into text_len
        store 0x05 into text at text_len
        add text_len 1
        store it into text_len
    end

    # Advance to next token
    add tok_idx 1
    store it into tok_idx
end

# ── Patch deferred call rel32 fixups ────────────────────────
store 0 into i
while compare i call_fixup_count
    load from call_patch at i
    store it into cf_patch
    load from call_func at i
    store it into temp2
    load from func_offset at temp2
    store it into temp3
    if equal temp3 0
        # unresolved function target
        return 197
    end

    # rel32 = target - (patch_pos + 4)
    add cf_patch 4
    subtract temp3 it
    store it into temp4

    bitand temp4 0xFF
    store it into text at cf_patch
    add cf_patch 1
    store it into cf_patch
    bitand temp4 0xFF00
    divide it 256
    store it into text at cf_patch
    add cf_patch 1
    store it into cf_patch
    bitand temp4 0xFF0000
    divide it 65536
    store it into text at cf_patch
    add cf_patch 1
    store it into cf_patch
    bitand temp4 0xFF000000
    divide it 16777216
    store it into text at cf_patch

    add i 1
    store it into i
end

# ── DEBUG: Verify 0xB5 byte survived patching ──
if compare rsi_check_pos 0
    load from text at rsi_check_pos
    if compare it 181
        return 199
    end
end

# ── Patch frame size ──
# Frame size = vreg_total_size rounded up to 16
# For "return 42" with no variables, frame_size = 0
add vreg_total_size 15
store it into temp
bitand temp 0xFFFFFFF0
store it into frame_size

# Patch the 4 bytes at frame_patch_offset
bitand frame_size 0xFF
store it into text at frame_patch_offset
add frame_patch_offset 1
store it into frame_patch_offset

bitand frame_size 0xFF00
divide it 256
store it into text at frame_patch_offset
add frame_patch_offset 1
store it into frame_patch_offset

bitand frame_size 0xFF0000
divide it 65536
store it into text at frame_patch_offset
add frame_patch_offset 1
store it into frame_patch_offset

bitand frame_size 0xFF000000
divide it 16777216
store it into text at frame_patch_offset

# ─── Phase 6: Write ELF binary to stdout ─────────────────────────────────────

# ELF header (64 bytes) + Program header (56 bytes) = 120 bytes header
# Then .text, then .data

a total_size
add text_len data_len
add it 120
store it into total_size

# Virtual addresses
a vaddr_base
store 0x400000 into vaddr_base
a entry_point
add vaddr_base 120
store it into entry_point

# data_vaddr = vaddr_base + 120 + text_len
a data_vaddr
add vaddr_base 120
add it text_len
store it into data_vaddr

# ── Build ELF header in output buffer ──
store 0 into output_len

# Magic: 0x7F 'E' 'L' 'F'
store 0x7F into output at output_len
add output_len 1
store it into output_len
store 69 into output at output_len
add output_len 1
store it into output_len
store 76 into output at output_len
add output_len 1
store it into output_len
store 70 into output at output_len
add output_len 1
store it into output_len

# Class=2 (64-bit), Data=1 (LE), Version=1, OS/ABI=0
store 2 into output at output_len
add output_len 1
store it into output_len
store 1 into output at output_len
add output_len 1
store it into output_len
