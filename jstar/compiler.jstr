# ═══════════════════════════════════════════════════════════════════════════════
# compiler.jstr — JStar self-hosted compiler
#
# Reads JStar source from stdin, writes ELF x86-64 binary to stdout.
# Usage: ./compiler < input.jstr > output.elf
#
# Architecture: single-pass tokenize, single-pass codegen.
# Large buffers use global declarations (.data section); temporaries are stack-local.
#
# Self-hosting verification:
#   cargo run -- jstar compile --raw --input compiler.jstr -o jstar1
#   ./jstar1 < compiler.jstr > jstar2
#   chmod +x jstar2
#   ./jstar2 < compiler.jstr > jstar3
#   cmp jstar2 jstar3   # byte-identical = self-hosting verified
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Data declarations ────────────────────────────────────────────────────────

# Input buffer: source code read from stdin (256KB for self-compilation)
global byte input 262144
global input_len

# Output buffer: ELF binary written to stdout (256KB for self-compilation)
global byte output 262144
global output_len

# .text section (machine code)
global byte text 65536
global text_len

# .data section (string literals)
global byte datasec 8192
global data_len

# ─── Token arrays ────────────────────────────────────────────────────────────
# Each token is described by its start offset in input and its length.
# Token type codes:
#   0 = unknown/variable    1 = return     2 = add        3 = subtract
#   4 = multiply            5 = divide     6 = store      7 = load
#   8 = compare             9 = equal     10 = less      11 = greater
#  12 = print              13 = if        14 = else      15 = while
#  16 = end                17 = a/an      18 = the       19 = into
#  20 = from               21 = at        22 = it/that   23 = define
#  24 = with               25 = call      26 = syscall   27 = bitand
#  28 = bitor              29 = bitxor    30 = shift     31 = halt/exit
#  32 = addressof          33 = allocate  34 = modulo    35 = negate
#  36 = push               37 = pop       38 = bitnot
#  50 = literal (number)
#  51 = string literal
#  52 = variable name (non-keyword identifier)
#  53 = byte (type noun)   54 = long (type noun)  55 = integer (type noun)
#  56 = short (type noun)  57 = boolean (type noun) 58 = char (type noun)
#  59 = global (scope keyword)

global long tok_start 32768
global long tok_len 32768
global long tok_type 32768
global tok_count

# ─── Compiler state ──────────────────────────────────────────────────────────

# Virtual register tracking
global vreg_next
global long vreg_size 2048
global vreg_total_size
global frame_size

# Variable name-to-vreg mapping (parallel arrays)
# var_name_start[i], var_name_len[i] = token boundaries in input
# var_vreg[i] = the vreg assigned to variable i
# var_type[i] = element type (0=qword/int, 1=byte)
global long var_name_start 512
global long var_name_len 512
global long var_vreg 512
global long var_type 512
global long var_offset 512
global var_count

# Label/fixup tracking for jumps
global long label_offset 512
global label_count
global long fixup_patch 512
global long fixup_label 512
global fixup_count

# Control flow stack (for nested if/while)
# Each entry: [kind, label_cond, label_body, label_else, label_end]
# kind: 0=if, 1=while
global long cf_kind 256
global long cf_label_cond 256
global long cf_label_end 256
global cf_depth

# Function tracking
global long func_name_start 256
global long func_name_len 256
global long func_offset 256
global long func_param_count 256
global long func_param_start 256
global long func_skip_patch 256
global func_count
global is_in_function
global current_func_idx
global func_cf_base

# Call fixup tracking (separate from jump fixups)
global long call_patch 256
global long call_func 256
global call_fixup_count

# Debug: track 0xB5 write position for post-patch verification
global rsi_check_pos

# Misc temporaries
a i
a j
a k
a ch
a temp
a temp2
a temp3
a temp4
a matched
a param_cursor
a param_type
a param_size
a param_name_idx
a param_count_temp
a param_start
a param_type_valid
a param_last_name_idx
a param_token_len
a param_with_start
a param_char
a arg_idx
a arg_tok
a arg_type
a arg_offset
a param_base
a call_func_idx
a tok_idx
a byte_val

# Variable lookup temporaries
a lookup_src
a lookup_len
a lookup_i
a lookup_j
a lookup_k
a lookup_a
a lookup_b
a lookup_match
a lookup_result
a lookup_cmp_start
a lookup_cmp_len

# Operand loading temporaries
a op_type
a op_val
a op_off

# Saved first-operand for two-operand instructions
a a_type
a a_val
a a_off

# Indexed store/load: X's offset and type
a x_off
a x_type
a x_idx

# Syscall arg count
a sc_argc

# Stdin read loop flag
global read_done

# Comparison and control flow
a cmp_op
a cf_patch

# ─── Phase 1: Read input from stdin ──────────────────────────────────────────

store 0 into input_len
store 0 into output_len
store 0 into text_len
store 0 into data_len
store 0 into tok_count
store 0 into vreg_next
store 0 into vreg_total_size
store 0 into var_count
store 0 into label_count
store 0 into fixup_count
store 0 into cf_depth
store 0 into func_count
store 0 into is_in_function
store 0 into current_func_idx
store 0 into func_cf_base
store 0 into call_fixup_count

# Read from stdin (fd=0) into input buffer, looping until EOF
store 0 into input_len
store 0 into read_done
while equal read_done 0
    addressof input
    add it input_len
    store it into temp
    subtract 262144 input_len
    store it into temp2
    syscall 0 0 temp temp2
    store it into temp3
    if equal temp3 0
        store 1 into read_done
    else
        add input_len temp3
        store it into input_len
    end
end

# ─── Phase 2: Tokenize ───────────────────────────────────────────────────────
# Split input into tokens by whitespace. Classify each token.

store 0 into i
store 0 into tok_count

while compare i input_len
    # Skip whitespace (space=32, tab=9, newline=10, carriage return=13)
    load from input at i
    store it into ch

    # Check if whitespace
    store 0 into matched
    if equal ch 32
        store 1 into matched
    end
    if equal ch 10
        store 1 into matched
    end
    if equal ch 9
        store 1 into matched
    end
    if equal ch 13
        store 1 into matched
    end

    if equal matched 0
        # Not whitespace — start of a token

        # Check for comment line (# at start of line or after whitespace)
        if equal ch 35
            # Skip until end of line or end of input
            store 0 into temp3
            while equal temp3 0
                if equal i input_len
                    store 1 into temp3
                else
                    load from input at i
                    store it into temp4
                    add i 1
                    store it into i
                    if equal temp4 10
                        store 1 into temp3
                    end
                end
            end
            store 1 into matched
        end

        if equal matched 0
            # Check for string literal (starts with double quote = 34)
            if equal ch 34
                # String literal: scan until closing quote
                add i 1
                store it into i
                store i into temp2

                store 0 into matched
                while equal matched 0
                    if equal i input_len
                        store 1 into matched
                    else
                        load from input at i
                        if equal it 34
                            store 1 into matched
                        else
                            add i 1
                            store it into i
                        end
                    end
                end

                # Record string token: start=temp2, len=i-temp2
                subtract i temp2
                store it into temp3

                store temp2 into tok_start at tok_count
                store temp3 into tok_len at tok_count
                store 51 into tok_type at tok_count

                add tok_count 1
                store it into tok_count

                # Skip closing quote
                add i 1
                store it into i
            else
                # Regular token: scan until whitespace
                store i into temp2

                store 0 into matched
                while equal matched 0
                    if equal i input_len
                        store 1 into matched
                    else
                        load from input at i
                        store it into temp4
                        # Check whitespace
                        store 0 into temp3
                        if equal temp4 32
                            store 1 into temp3
                        end
                        if equal temp4 10
                            store 1 into temp3
                        end
                        if equal temp4 9
                            store 1 into temp3
                        end
                        if equal temp4 13
                            store 1 into temp3
                        end
                        if equal temp3 0
                            add i 1
                            store it into i
                        else
                            store 1 into matched
                        end
                    end
                end

                # Token boundaries: start=temp2, len=i-temp2
                subtract i temp2
                store it into temp3

                store temp2 into tok_start at tok_count
                store temp3 into tok_len at tok_count

                # ── Classify token ─────────────────────────────────
                # First check if it is a number (first char is digit 0-9)
                load from input at temp2
                store it into ch

                store 0 into temp4
                if greater ch 47
                    if less ch 58
                        store 1 into temp4
                    end
                end

                if compare temp4 0
                    # It is a number literal
                    store 50 into tok_type at tok_count
                else
                    # Not a number — classify by keyword matching
                    # We pack the first 8 bytes into a qword for fast comparison.
                    # Also check length to disambiguate.

                    store 52 into tok_type at tok_count

                    # ── Length-based keyword dispatch ──────────────
                    # Length 1: a
                    if equal temp3 1
                        load from input at temp2
                        if equal it 97
                            store 17 into tok_type at tok_count
                        end
                    end

                    # Length 2: an, at, if, it, or, to
                    if equal temp3 2
                        load from input at temp2
                        store it into ch
                        add temp2 1
                        store it into temp4
                        load from input at temp4
                        store it into byte_val

                        # "an" = 97,110
                        if equal ch 97
                            if equal byte_val 110
                                store 17 into tok_type at tok_count
                            end
                        end
                        # "at" = 97,116
                        if equal ch 97
                            if equal byte_val 116
                                store 21 into tok_type at tok_count
                            end
                        end
                        # "if" = 105,102
                        if equal ch 105
                            if equal byte_val 102
                                store 13 into tok_type at tok_count
                            end
                        end
                        # "it" = 105,116
                        if equal ch 105
                            if equal byte_val 116
                                store 22 into tok_type at tok_count
                            end
                        end
                        # "or" -- skip (not used as keyword in codegen)
                        # "to" = 116,111
                        if equal ch 116
                            if equal byte_val 111
                                store 19 into tok_type at tok_count
                            end
                        end
                    end

                    # Length 3: add, end, the, pop
                    if equal temp3 3
                        load from input at temp2
                        store it into ch
                        add temp2 1
                        store it into temp4
                        load from input at temp4
                        store it into byte_val
                        add temp2 2
                        store it into temp4
                        load from input at temp4
                        store it into k

                        # "add" = 97,100,100
                        if equal ch 97
                            if equal byte_val 100
                                if equal k 100
                                    store 2 into tok_type at tok_count
                                end
                            end
                        end
                        # "end" = 101,110,100
                        if equal ch 101
                            if equal byte_val 110
                                if equal k 100
                                    store 16 into tok_type at tok_count
                                end
                            end
                        end
                        # "the" = 116,104,101
                        if equal ch 116
                            if equal byte_val 104
                                if equal k 101
                                    store 18 into tok_type at tok_count
                                end
                            end
                        end
                        # "pop" = 112,111,112
                        if equal ch 112
                            if equal byte_val 111
                                if equal k 112
                                    store 37 into tok_type at tok_count
                                end
                            end
                        end
                        # "int" = 105,110,116
                        if equal ch 105
                            if equal byte_val 110
                                if equal k 116
                                    store 55 into tok_type at tok_count
                                end
                            end
                        end
                    end

                    # Length 4: call, else, from, halt, into, load, less, long, byte, that, void, with, push, exit, char, bool
                    if equal temp3 4
                        load from input at temp2
                        store it into ch
                        add temp2 1
                        store it into temp4
                        load from input at temp4
                        store it into byte_val

                        # "call" = 99,97,108,108
                        if equal ch 99
                            if equal byte_val 97
                                store 25 into tok_type at tok_count
                            end
                        end
                        # "else" = 101,108,115,101
                        if equal ch 101
                            if equal byte_val 108
                                store 14 into tok_type at tok_count
                            end
                        end
                        # "from" = 102,114,111,109
                        if equal ch 102
                            if equal byte_val 114
                                store 20 into tok_type at tok_count
                            end
                        end
                        # "halt" = 104,97,108,116
                        if equal ch 104
                            if equal byte_val 97
                                store 31 into tok_type at tok_count
                            end
                        end
                        # "into" = 105,110,116,111
                        if equal ch 105
                            if equal byte_val 110
                                store 19 into tok_type at tok_count
                            end
                        end
                        # "load" = 108,111,97,100
                        if equal ch 108
                            if equal byte_val 111
                                store 7 into tok_type at tok_count
                            end
                        end
                        # "less" = 108,101,115,115
                        if equal ch 108
                            if equal byte_val 101
                                store 10 into tok_type at tok_count
                            end
                        end
                        # "long" = 108,111,110,103
                        # conflicts with "load" above at ch=108,byte_val=111
                        # need to check 3rd char: 'a' for load, 'n' for long
                        # Fix: be more precise
                        # Actually "load" second char is 'o'=111 and "long" second char is 'o'=111
                        # Third char: load='a'=97, long='n'=110
                        if equal ch 108
                            if equal byte_val 111
                                add temp2 2
                                store it into temp4
                                load from input at temp4
                                if equal it 110
                                    # "long"
                                    store 54 into tok_type at tok_count
                                end
                            end
                        end
                        # "byte" = 98,121,116,101
                        if equal ch 98
                            if equal byte_val 121
                                store 53 into tok_type at tok_count
                            end
                        end
                        # "that" = 116,104,97,116
                        if equal ch 116
                            if equal byte_val 104
                                add temp2 2
                                store it into temp4
                                load from input at temp4
                                if equal it 97
                                    store 22 into tok_type at tok_count
                                end
                            end
                        end
                        # "with" = 119,105,116,104
                        if equal ch 119
                            if equal byte_val 105
                                store 24 into tok_type at tok_count
                            end
                        end
                        # "push" = 112,117,115,104
                        if equal ch 112
                            if equal byte_val 117
                                store 36 into tok_type at tok_count
                            end
                        end
                        # "exit" = 101,120,105,116
                        if equal ch 101
                            if equal byte_val 120
                                store 31 into tok_type at tok_count
                            end
                        end
                        # "char" = 99,104,97,114
                        if equal ch 99
                            if equal byte_val 104
                                store 58 into tok_type at tok_count
                            end
                        end
                        # "bool" = 98,111,111,108
                        if equal ch 98
                            if equal byte_val 111
                                store 57 into tok_type at tok_count
                            end
                        end
                        # "void" -- skip (not needed for codegen)
                    end

                    # Length 5: equal, print, shift, store, while, short
                    if equal temp3 5
                        load from input at temp2
                        store it into ch
                        add temp2 1
                        store it into temp4
                        load from input at temp4
                        store it into byte_val

                        # "equal" = 101,113
                        if equal ch 101
                            if equal byte_val 113
                                store 9 into tok_type at tok_count
                            end
                        end
                        # "print" = 112,114
                        if equal ch 112
                            if equal byte_val 114
                                store 12 into tok_type at tok_count
                            end
                        end
                        # "shift" = 115,104
                        if equal ch 115
                            if equal byte_val 104
                                store 30 into tok_type at tok_count
                            end
                        end
                        # "store" = 115,116
                        if equal ch 115
                            if equal byte_val 116
                                store 6 into tok_type at tok_count
                            end
                        end
                        # "while" = 119,104
                        if equal ch 119
                            if equal byte_val 104
                                store 15 into tok_type at tok_count
                            end
                        end
                        # "short" = 115,104 -- conflicts with "shift"!
                        # Need 3rd char: shift='i'=105, short='o'=111
                        if equal ch 115
                            if equal byte_val 104
                                add temp2 2
                                store it into temp4
                                load from input at temp4
                                if equal it 111
                                    store 56 into tok_type at tok_count
                                end
                            end
                        end
                        # "bitor" = 98,105
                        if equal ch 98
                            if equal byte_val 105
                                add temp2 2
                                store it into temp4
                                load from input at temp4
                                if equal it 116
                                    store 28 into tok_type at tok_count
                                end
                            end
                        end
                    end

                    # Length 6: define, divide, global, modulo, negate, return, bitand, bitxor, bitnot
                    if equal temp3 6
                        load from input at temp2
                        store it into ch
                        add temp2 1
                        store it into temp4
                        load from input at temp4
                        store it into byte_val

                        # "define" = 100,101
                        if equal ch 100
                            if equal byte_val 101
                                store 23 into tok_type at tok_count
                            end
                        end
                        # "divide" = 100,105
                        if equal ch 100
                            if equal byte_val 105
                                store 5 into tok_type at tok_count
                            end
                        end
                        # "global" = 103,108
                        if equal ch 103
                            if equal byte_val 108
                                store 59 into tok_type at tok_count
                            end
                        end
                        # "modulo" = 109,111
                        if equal ch 109
                            store 34 into tok_type at tok_count
                        end
                        # "negate" = 110,101
                        if equal ch 110
                            store 35 into tok_type at tok_count
                        end
                        # "return" = 114,101
                        if equal ch 114
                            if equal byte_val 101
                                store 1 into tok_type at tok_count
                            end
                        end
                        # "bitand" = 98,105,116,97
                        if equal ch 98
                            if equal byte_val 105
                                add temp2 4
                                store it into temp4
                                load from input at temp4
                                if equal it 110
                                    store 27 into tok_type at tok_count
                                end
                            end
                        end
                        # "bitxor" = 98,105,116,120
                        if equal ch 98
                            if equal byte_val 105
                                add temp2 4
                                store it into temp4
                                load from input at temp4
                                if equal it 111
                                    store 29 into tok_type at tok_count
                                end
                            end
                        end
                        # "bitnot" = 98,105,116,110,111,116
                        if equal ch 98
                            if equal byte_val 105
                                add temp2 4
                                store it into temp4
                                load from input at temp4
                                if equal it 116
                                    store 38 into tok_type at tok_count
                                end
                            end
                        end
                    end

                    # Length 7: compare, greater, integer, syscall, boolean
                    if equal temp3 7
                        load from input at temp2
                        store it into ch

                        # "compare" = 99
                        if equal ch 99
                            store 8 into tok_type at tok_count
                        end
                        # "greater" = 103
                        if equal ch 103
                            store 11 into tok_type at tok_count
                        end
                        # "integer" = 105
                        if equal ch 105
                            store 55 into tok_type at tok_count
                        end
                        # "syscall" = 115
                        if equal ch 115
                            store 26 into tok_type at tok_count
                        end
                        # "boolean" = 98
                        if equal ch 98
                            store 57 into tok_type at tok_count
                        end
                    end

                    # Length 8: subtract, multiply, allocate, addressof
                    if equal temp3 8
                        load from input at temp2
                        store it into ch

                        # "subtract" = 115
                        if equal ch 115
                            store 3 into tok_type at tok_count
                        end
                        # "multiply" = 109
                        if equal ch 109
                            store 4 into tok_type at tok_count
                        end
                        # "allocate" = 97
                        if equal ch 97
                            add temp2 1
                            store it into temp4
                            load from input at temp4
                            if equal it 108
                                store 33 into tok_type at tok_count
                            else
                                # "addressof" would be length 9
                                store 52 into tok_type at tok_count
                            end
                        end
                    end

                    # Length 9: addressof
                    if equal temp3 9
                        load from input at temp2
                        store it into ch
                        if equal ch 97
                            add temp2 1
                            store it into temp4
                            load from input at temp4
                            if equal it 100
                                store 32 into tok_type at tok_count
                            end
                        end
                    end
                end

                add tok_count 1
                store it into tok_count
            end
        end
    else
        # Whitespace: skip
        add i 1
        store it into i
    end
end

# ─── Phase 3: Parse number literals ──────────────────────────────────────────
# Convert ASCII digit sequences in input to integer values.
# Store parsed values in a parallel array.

global long tok_value 32768

store 0 into i
while compare i tok_count
    load from tok_type at i
    if equal it 50
        # Parse number from input bytes (decimal or hex with 0x prefix)
        load from tok_start at i
        store it into temp
        load from tok_len at i
        store it into temp2

        # Check for hex prefix: 0x (bytes 48, 120)
        store 0 into temp3
        store 0 into matched
        if greater temp2 2
            load from input at temp
            if equal it 48
                add temp 1
                load from input at it
                if equal it 120
                    # Hex literal: parse digits after "0x"
                    store 1 into matched
                    store 0 into temp3
                    store 2 into j
                    while compare j temp2
                        add temp j
                        store it into temp4
                        load from input at temp4
                        store it into k

                        # Convert hex digit to value (0-15)
                        # '0'-'9' = 48-57 → 0-9
                        # 'a'-'f' = 97-102 → 10-15
                        # 'A'-'F' = 65-70 → 10-15
                        if greater k 96
                            subtract k 87
                            store it into k
                        else
                            if greater k 64
                                subtract k 55
                                store it into k
                            else
                                subtract k 48
                                store it into k
                            end
                        end

                        multiply temp3 16
                        add it k
                        store it into temp3

                        add j 1
                        store it into j
                    end
                end
            end
        end

        if equal matched 0
            # Decimal literal
            store 0 into temp3
            store 0 into j
            while compare j temp2
                add temp j
                store it into temp4
                load from input at temp4
                subtract it 48
                store it into k

                multiply temp3 10
                add it k
                store it into temp3

                add j 1
                store it into j
            end
        end

        store temp3 into tok_value at i
    else
        store 0 into tok_value at i
    end

    add i 1
    store it into i
end

# ─── Phase 4: Pre-scan for function definitions ─────────────────────────────
# Find all "define" keywords, record function name and token range.

store 0 into i
store 0 into func_count
while compare i tok_count
    load from tok_type at i
    if equal it 23
        # "define" — next token is function name
        add i 1
        store it into temp

        if compare temp tok_count
            load from tok_start at temp
            store it into temp2
            load from tok_len at temp
            store it into temp3

            store temp2 into func_name_start at func_count
            store temp3 into func_name_len at func_count
            store 0 into func_param_count at func_count
            store 0 into func_param_start at func_count

            add func_count 1
            store it into func_count
        end
    end

    add i 1
    store it into i
end

# ─── Helper: emit a byte to the text buffer ──────────────────────────────────
# Since we can not use functions, we use inline patterns:
#   store BYTE into text at text_len
#   add text_len 1
#   store it into text_len

# ─── Phase 5: Code generation ────────────────────────────────────────────────
# Walk tokens left to right. Emit x86-64 machine code.

# Step 1: Emit function bodies first (non-_start code)
# Step 2: Emit _start (top-level code)
# Step 3: Apply fixups

# _start is emitted first, but define/call blocks are handled inline:
# each function body is emitted behind a jump so top-level execution skips it.

# ── Emit prologue for _start ──
# push rbp = 0x55
store 0x55 into text at text_len
add text_len 1
store it into text_len

# mov rbp, rsp = 0x48 0x89 0xE5
store 0x48 into text at text_len
add text_len 1
store it into text_len
store 0x89 into text at text_len
add text_len 1
store it into text_len
store 0xE5 into text at text_len
add text_len 1
store it into text_len

# ── Stack probing prologue ──
# Runtime probing loop: loads frame_size into ecx, subtracts 4096 per
# iteration while touching each page, then subtracts the remainder.
# This prevents segfault from skipping the stack guard page on large frames.
#
# mov ecx, FRAME_SIZE    → B9 xx xx xx xx  (patch later)
# probe_loop:
# cmp ecx, 4096          → 81 F9 00 10 00 00
# jle probe_done (+22)   → 0F 8E 16 00 00 00
# sub rsp, 4096          → 48 81 EC 00 10 00 00
# mov rax, [rsp]         → 48 8B 04 24
# sub ecx, 4096          → 81 E9 00 10 00 00
# jmp probe_loop (-34)   → E9 DE FF FF FF
# probe_done:
# sub rsp, rcx           → 48 29 CC

# mov ecx, FRAME_SIZE (placeholder)
store 0xB9 into text at text_len
add text_len 1
store it into text_len
# Record patch position
global frame_patch_offset
store text_len into frame_patch_offset
# Emit 4 placeholder bytes for frame_size
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len

# cmp ecx, 4096 → 81 F9 00 10 00 00
store 0x81 into text at text_len
add text_len 1
store it into text_len
store 0xF9 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0x10 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len

# jle probe_done (+22) → 0F 8E 16 00 00 00
store 0x0F into text at text_len
add text_len 1
store it into text_len
store 0x8E into text at text_len
add text_len 1
store it into text_len
store 0x16 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len

# sub rsp, 4096 → 48 81 EC 00 10 00 00
store 0x48 into text at text_len
add text_len 1
store it into text_len
store 0x81 into text at text_len
add text_len 1
store it into text_len
store 0xEC into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0x10 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len

# mov rax, [rsp] → 48 8B 04 24
store 0x48 into text at text_len
add text_len 1
store it into text_len
store 0x8B into text at text_len
add text_len 1
store it into text_len
store 0x04 into text at text_len
add text_len 1
store it into text_len
store 0x24 into text at text_len
add text_len 1
store it into text_len

# sub ecx, 4096 → 81 E9 00 10 00 00
store 0x81 into text at text_len
add text_len 1
store it into text_len
store 0xE9 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0x10 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len
store 0 into text at text_len
add text_len 1
store it into text_len

# jmp probe_loop (-34) → E9 DE FF FF FF
store 0xE9 into text at text_len
add text_len 1
store it into text_len
store 0xDE into text at text_len
add text_len 1
store it into text_len
store 0xFF into text at text_len
add text_len 1
store it into text_len
store 0xFF into text at text_len
add text_len 1
store it into text_len
store 0xFF into text at text_len
add text_len 1
store it into text_len

# sub rsp, rcx → 48 29 CC
store 0x48 into text at text_len
add text_len 1
store it into text_len
store 0x29 into text at text_len
add text_len 1
store it into text_len
store 0xCC into text at text_len
add text_len 1
store it into text_len

# ── Walk tokens and emit code ──
store 0 into tok_idx

while compare tok_idx tok_count
    load from tok_type at tok_idx
    store it into temp

    # ── Function define: define(23) NAME ... end ────────────
    if equal temp 23
        # Nested function definitions are unsupported
        if compare is_in_function 0
            return 198
        end

        # NAME token
        add tok_idx 1
        store it into temp2
        if equal temp2 tok_count
            return 198
        end
        load from tok_type at temp2
        if compare it 52
            return 198
        end

        # Resolve function index by name from pre-scan table
        load from tok_start at temp2
        store it into lookup_src
        load from tok_len at temp2
        store it into lookup_len
        store 0 into lookup_i
        subtract 0 1
        store it into lookup_result
        while compare lookup_i func_count
            load from func_name_len at lookup_i
            store it into lookup_cmp_len
            if equal lookup_len lookup_cmp_len
                load from func_name_start at lookup_i
                store it into lookup_cmp_start
                store 1 into lookup_match
                store 0 into lookup_j
                while compare lookup_j lookup_len
                    add lookup_src lookup_j
                    store it into lookup_k
                    load from input at lookup_k
                    store it into lookup_a
                    add lookup_cmp_start lookup_j
                    store it into lookup_k
                    load from input at lookup_k
                    store it into lookup_b
                    if compare lookup_a lookup_b
                        store 0 into lookup_match
                    end
                    add lookup_j 1
                    store it into lookup_j
                end
                if compare lookup_match 0
                    store lookup_i into lookup_result
                end
            end
            add lookup_i 1
            store it into lookup_i
        end
        subtract 0 1
        store it into temp3
        if equal lookup_result temp3
            return 198
        end
        store lookup_result into current_func_idx

        # Parse optional parameter list: "with TYPE NAME ..."
        store var_count into param_start
        store 0 into param_count_temp
        add temp2 1
        store it into param_cursor
        store temp2 into param_last_name_idx
        if compare param_cursor tok_count
            # no trailing tokens -> no parameters
        else
            load from tok_type at param_cursor
            store it into temp3
            store temp3 into text at text_len
            add text_len 1
            store it into text_len
            if equal it 24
                store 0xAB into text at text_len
                add text_len 1
                store it into text_len
                add param_cursor 1
                store it into param_cursor
                while compare param_cursor tok_count
                    load from tok_type at param_cursor
                    store it into param_type
                    store 0 into param_type_valid
                    if equal param_type 53
                        store 1 into param_type_valid
                    end
                    if equal param_type 54
                        store 1 into param_type_valid
                    end
                    if equal param_type 55
                        store 1 into param_type_valid
                    end
                    if equal param_type 56
                        store 1 into param_type_valid
                    end
                    if equal param_type 57
                        store 1 into param_type_valid
                    end
                    if equal param_type 58
                        store 1 into param_type_valid
                    end
                    if compare param_type_valid 0
                        store 0xAC into text at text_len
                        add text_len 1
                        store it into text_len
                        store tok_count into param_cursor
                    else
                        add param_cursor 1
                        store it into param_name_idx
                        if compare param_name_idx tok_count
                            return 195
                        end
                        load from tok_start at param_name_idx
                        store it into var_name_start at var_count
                        load from tok_len at param_name_idx
                        store it into var_name_len at var_count
                        store 8 into param_size
                        store 0 into var_type at var_count
                        if equal param_type 53
                            store 1 into param_size
                            store 1 into var_type at var_count
                        end
                        add vreg_total_size param_size
                        store it into vreg_total_size
                        subtract 0 vreg_total_size
                        store it into var_offset at var_count
                        add var_count 1
                        store it into var_count
                        add param_count_temp 1
                        store it into param_count_temp
                        store param_name_idx into param_last_name_idx
                        add param_cursor 1
                        store it into param_cursor
                    end
                end
                if compare param_count_temp 0
                    return 195
                end
                store param_last_name_idx into temp2
            end
        end

        store param_start into func_param_start at current_func_idx
        store param_count_temp into func_param_count at current_func_idx

        # Emit jump over function body so top-level execution skips it
        # jmp rel32 = 0xE9 + placeholder
        store 0xE9 into text at text_len
        add text_len 1
        store it into text_len
        store text_len into temp3
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store temp3 into func_skip_patch at current_func_idx

        # Function entry point is immediately after the jump
        store text_len into func_offset at current_func_idx
        store 1 into is_in_function
        store cf_depth into func_cf_base
        # Copy argument registers into the shared stack frame so parameters behave like locals
        store 0xBB into text at text_len
        add text_len 1
        store it into text_len
        load from func_param_count at current_func_idx
        store it into param_count_temp
        if greater param_count_temp 6
            return 195
        end
        load from func_param_start at current_func_idx
        store it into param_base
        store 0 into arg_idx
        while compare arg_idx param_count_temp
            store param_base into param_name_idx
            add param_name_idx arg_idx
            store it into param_name_idx
            load from var_offset at param_name_idx
            store it into arg_offset
            if equal arg_idx 0
                store 0x57 into text at text_len
                add text_len 1
                store it into text_len
            else
                if equal arg_idx 1
                    store 0x56 into text at text_len
                    add text_len 1
                    store it into text_len
                else
                    if equal arg_idx 2
                        store 0x52 into text at text_len
                        add text_len 1
                        store it into text_len
                    else
                        if equal arg_idx 3
                            store 0x51 into text at text_len
                            add text_len 1
                            store it into text_len
                        else
                            if equal arg_idx 4
                                store 0x41 into text at text_len
                                add text_len 1
                                store it into text_len
                                store 0x50 into text at text_len
                                add text_len 1
                                store it into text_len
                            else
                                if equal arg_idx 5
                                    store 0x41 into text at text_len
                                    add text_len 1
                                    store it into text_len
                                    store 0x51 into text at text_len
                                    add text_len 1
                                    store it into text_len
                                else
                                    return 195
                                end
                            end
                        end
                    end
                end
            end
            store 0x58 into text at text_len
            add text_len 1
            store it into text_len
            store arg_tok into temp2
            add arg_idx 1
            store it into arg_idx
        end
        store 0xDD into text at text_len
        add text_len 1
        store it into text_len

        # Next iteration should start at first body token (right after NAME)
        store temp2 into tok_idx
        store 0 into temp
    end

    # ── Function call: call(25) NAME ────────────────────────
    if equal temp 25
        # NAME token
        add tok_idx 1
        store it into temp2
        if equal temp2 tok_count
            return 197
        end
        load from tok_type at temp2
        if compare it 52
            return 197
        end

        # Resolve function index by name
        load from tok_start at temp2
        store it into lookup_src
        load from tok_len at temp2
        store it into lookup_len
        store 0 into lookup_i
        subtract 0 1
        store it into lookup_result
        while compare lookup_i func_count
            load from func_name_len at lookup_i
            store it into lookup_cmp_len
            if equal lookup_len lookup_cmp_len
                load from func_name_start at lookup_i
                store it into lookup_cmp_start
                store 1 into lookup_match
                store 0 into lookup_j
                while compare lookup_j lookup_len
                    add lookup_src lookup_j
                    store it into lookup_k
                    load from input at lookup_k
                    store it into lookup_a
                    add lookup_cmp_start lookup_j
                    store it into lookup_k
                    load from input at lookup_k
                    store it into lookup_b
                    if compare lookup_a lookup_b
                        store 0 into lookup_match
                    end
                    add lookup_j 1
                    store it into lookup_j
                end
                if compare lookup_match 0
                    store lookup_i into lookup_result
                end
            end
            add lookup_i 1
            store it into lookup_i
        end
        subtract 0 1
        store it into temp3
        if equal lookup_result temp3
            return 197
        end
        store lookup_result into call_func_idx
        load from func_param_count at call_func_idx
        store it into param_count_temp
        load from func_param_start at call_func_idx
        store it into param_base
        store 0 into arg_idx
        if greater param_count_temp 6
            return 195
        end

        # Evaluate call arguments (must match parameter count) and write them into the shared stack frame
        while compare arg_idx param_count_temp
            add temp2 1
            store it into arg_tok
            if compare arg_tok tok_count
                return 197
            end
            load from tok_type at arg_tok
            store it into arg_type
            if equal arg_type 50
                load from tok_value at arg_tok
                store it into temp3
                store 0xB8 into text at text_len
                add text_len 1
                store it into text_len
                bitand temp3 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand temp3 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand temp3 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand temp3 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            else
                if equal arg_type 22
                    # "it" already lives in rax (no-op)
                else
                    # Variable reference: load into rax
                    load from tok_start at arg_tok
                    store it into lookup_src
                    load from tok_len at arg_tok
                    store it into lookup_len
                    store 0 into lookup_i
                    subtract 0 1
                    store it into lookup_result
                    while compare lookup_i var_count
                        load from var_name_len at lookup_i
                        store it into lookup_cmp_len
                        if equal lookup_len lookup_cmp_len
                            load from var_name_start at lookup_i
                            store it into lookup_cmp_start
                            store 1 into lookup_match
                            store 0 into lookup_j
                            while compare lookup_j lookup_len
                                add lookup_src lookup_j
                                store it into lookup_k
                                load from input at lookup_k
                                store it into lookup_a
                                add lookup_cmp_start lookup_j
                                store it into lookup_k
                                load from input at lookup_k
                                store it into lookup_b
                                if compare lookup_a lookup_b
                                    store 0 into lookup_match
                                end
                                add lookup_j 1
                                store it into lookup_j
                            end
                            if compare lookup_match 0
                                store lookup_i into lookup_result
                            end
                        end
                        add lookup_i 1
                        store it into lookup_i
                    end
                    load from var_offset at lookup_result
                    store it into op_off
                    store 0x48 into text at text_len
                    add text_len 1
                    store it into text_len
                    store 0x8B into text at text_len
                    add text_len 1
                    store it into text_len
                    store 0x85 into text at text_len
                    add text_len 1
                    store it into text_len
                    bitand op_off 0xFF
                    store it into text at text_len
                    add text_len 1
                    store it into text_len
                    bitand op_off 0xFF00
                    divide it 256
                    store it into text at text_len
                    add text_len 1
                    store it into text_len
                    bitand op_off 0xFF0000
                    divide it 65536
                    store it into text at text_len
                    add text_len 1
                    store it into text_len
                    bitand op_off 0xFF000000
                    divide it 16777216
                    store it into text at text_len
                    add text_len 1
                    store it into text_len
                end
            end
            # Move argument value into the appropriate register (push rax; pop target)
            store 0xAA into text at text_len
            add text_len 1
            store it into text_len
            store 0x50 into text at text_len
            add text_len 1
            store it into text_len
            if equal arg_idx 0
                store 0x5F into text at text_len
                add text_len 1
                store it into text_len
            else
                if equal arg_idx 1
                    store 0x5E into text at text_len
                    add text_len 1
                    store it into text_len
                else
                    if equal arg_idx 2
                        store 0x5A into text at text_len
                        add text_len 1
                        store it into text_len
                    else
                        if equal arg_idx 3
                            store 0x59 into text at text_len
                            add text_len 1
                            store it into text_len
                        else
                            if equal arg_idx 4
                                store 0x41 into text at text_len
                                add text_len 1
                                store it into text_len
                                store 0x58 into text at text_len
                                add text_len 1
                                store it into text_len
                            else
                                if equal arg_idx 5
                                    store 0x41 into text at text_len
                                    add text_len 1
                                    store it into text_len
                                    store 0x59 into text at text_len
                                    add text_len 1
                                    store it into text_len
                                else
                                    return 195
                                end
                            end
                        end
                    end
                end
            end
            store arg_tok into temp2
            add arg_idx 1
            store it into arg_idx
        end

        # Emit call rel32 (0xE8 + 4-byte displacement)
        store 0xE8 into text at text_len
        add text_len 1
        store it into text_len
        store text_len into cf_patch
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len
        store 0 into text at text_len
        add text_len 1
        store it into text_len

        # Patch immediately if target offset is known, else defer
        load from func_offset at call_func_idx
        store it into temp3
        if equal temp3 0
            store cf_patch into call_patch at call_fixup_count
            store call_func_idx into call_func at call_fixup_count
            add call_fixup_count 1
            store it into call_fixup_count
        else
            add cf_patch 4
            subtract temp3 it
            store it into temp4
            bitand temp4 0xFF
            store it into text at cf_patch
            add cf_patch 1
            store it into cf_patch
            bitand temp4 0xFF00
            divide it 256
            store it into text at cf_patch
            add cf_patch 1
            store it into cf_patch
            bitand temp4 0xFF0000
            divide it 65536
            store it into text at cf_patch
            add cf_patch 1
            store it into cf_patch
            bitand temp4 0xFF000000
            divide it 16777216
            store it into text at cf_patch
        end

        # Consume NAME token
        store temp2 into tok_idx
    end

    # ── return N ──────────────────────────────────────────────
    if equal temp 1
        # Next token is the value to return
        add tok_idx 1
        store it into tok_idx

        # Check if next token is a literal, "it", or variable
        load from tok_type at tok_idx
        store it into temp2

        if equal temp2 50
            # Literal: mov edi, N (0xBF + imm32)
            load from tok_value at tok_idx
            store it into temp3

            store 0xBF into text at text_len
            add text_len 1
            store it into text_len

            # Emit imm32 (little-endian)
            bitand temp3 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len

            bitand temp3 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len

            bitand temp3 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len

            bitand temp3 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        else
            if equal temp2 22
                # "it"/"that" — load from last result vreg
                # mov rdi, rax (result already in rax from last operation)
                # 0x48 0x89 0xC7 = mov rdi, rax
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x89 into text at text_len
                add text_len 1
                store it into text_len
                store 0xC7 into text at text_len
                add text_len 1
                store it into text_len
            else
                # Variable: look up and emit mov rdi, [rbp+offset]
                load from tok_start at tok_idx
                store it into lookup_src
                load from tok_len at tok_idx
                store it into lookup_len
                store 0 into lookup_i
                subtract 0 1
                store it into lookup_result
                while compare lookup_i var_count
                    load from var_name_len at lookup_i
                    store it into lookup_cmp_len
                    if equal lookup_len lookup_cmp_len
                        load from var_name_start at lookup_i
                        store it into lookup_cmp_start
                        store 1 into lookup_match
                        store 0 into lookup_j
                        while compare lookup_j lookup_len
                            add lookup_src lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_a
                            add lookup_cmp_start lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_b
                            if compare lookup_a lookup_b
                                store 0 into lookup_match
                            end
                            add lookup_j 1
                            store it into lookup_j
                        end
                        if compare lookup_match 0
                            store lookup_i into lookup_result
                        end
                    end
                    add lookup_i 1
                    store it into lookup_i
                end
                load from var_offset at lookup_result
                store it into op_off
                # mov rdi, [rbp+offset] = 0x48 0x8B 0xBD + disp32 LE
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x8B into text at text_len
                add text_len 1
                store it into text_len
                store 0xBD into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
        end

        # Top-level return exits process; function return uses ret
        if compare is_in_function 0
            # mov rax, rdi = 0x48 0x89 0xF8
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x89 into text at text_len
            add text_len 1
            store it into text_len
            store 0xF8 into text at text_len
            add text_len 1
            store it into text_len
            # ret
            store 0xC3 into text at text_len
            add text_len 1
            store it into text_len
        else
            # mov eax, 60 (sys_exit) = 0xB8 0x3C 0x00 0x00 0x00
            store 0xB8 into text at text_len
            add text_len 1
            store it into text_len
            store 0x3C into text at text_len
            add text_len 1
            store it into text_len
            store 0 into text at text_len
            add text_len 1
            store it into text_len
            store 0 into text at text_len
            add text_len 1
            store it into text_len
            store 0 into text at text_len
            add text_len 1
            store it into text_len

            # syscall = 0x0F 0x05
            store 0x0F into text at text_len
            add text_len 1
            store it into text_len
            store 0x05 into text at text_len
            add text_len 1
            store it into text_len
        end
    end

    # ── Arithmetic: add(2) subtract(3) multiply(4) divide(5) ────
    store 0 into matched
    if equal temp 2
        store 1 into matched
    end
    if equal temp 3
        store 1 into matched
    end
    if equal temp 4
        store 1 into matched
    end
    if equal temp 5
        store 1 into matched
    end
    if compare matched 0
        # Save the operation type
        store temp into cf_patch

        # Advance to first operand (A)
        add tok_idx 1
        store it into tok_idx

        # ── Resolve operand A ──
        load from tok_type at tok_idx
        store it into op_type
        store 0 into op_val
        store 0 into op_off
        if equal op_type 50
            load from tok_value at tok_idx
            store it into op_val
            store 0 into op_type
        end
        if equal op_type 22
            store 1 into op_type
        end
        if equal op_type 52
            store 2 into op_type
            load from tok_start at tok_idx
            store it into lookup_src
            load from tok_len at tok_idx
            store it into lookup_len
            store 0 into lookup_i
            subtract 0 1
            store it into lookup_result
            while compare lookup_i var_count
                load from var_name_len at lookup_i
                store it into lookup_cmp_len
                if equal lookup_len lookup_cmp_len
                    load from var_name_start at lookup_i
                    store it into lookup_cmp_start
                    store 1 into lookup_match
                    store 0 into lookup_j
                    while compare lookup_j lookup_len
                        add lookup_src lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_a
                        add lookup_cmp_start lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_b
                        if compare lookup_a lookup_b
                            store 0 into lookup_match
                        end
                        add lookup_j 1
                        store it into lookup_j
                    end
                    if compare lookup_match 0
                        store lookup_i into lookup_result
                    end
                end
                add lookup_i 1
                store it into lookup_i
            end
            load from var_offset at lookup_result
            store it into op_off
        end
        # Save A
        store op_type into a_type
        store op_val into a_val
        store op_off into a_off

        # Advance to second operand (B)
        add tok_idx 1
        store it into tok_idx

        # ── Resolve operand B ──
        load from tok_type at tok_idx
        store it into op_type
        store 0 into op_val
        store 0 into op_off
        if equal op_type 50
            load from tok_value at tok_idx
            store it into op_val
            store 0 into op_type
        end
        if equal op_type 22
            store 1 into op_type
        end
        if equal op_type 52
            store 2 into op_type
            load from tok_start at tok_idx
            store it into lookup_src
            load from tok_len at tok_idx
            store it into lookup_len
            store 0 into lookup_i
            subtract 0 1
            store it into lookup_result
            while compare lookup_i var_count
                load from var_name_len at lookup_i
                store it into lookup_cmp_len
                if equal lookup_len lookup_cmp_len
                    load from var_name_start at lookup_i
                    store it into lookup_cmp_start
                    store 1 into lookup_match
                    store 0 into lookup_j
                    while compare lookup_j lookup_len
                        add lookup_src lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_a
                        add lookup_cmp_start lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_b
                        if compare lookup_a lookup_b
                            store 0 into lookup_match
                        end
                        add lookup_j 1
                        store it into lookup_j
                    end
                    if compare lookup_match 0
                        store lookup_i into lookup_result
                    end
                end
                add lookup_i 1
                store it into lookup_i
            end
            load from var_offset at lookup_result
            store it into op_off
        end

        # ── Emit: load B into rcx ──
        if equal op_type 0
            # mov ecx, imm32 (0xB9 + imm32 LE)
            store 0xB9 into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        end
        if equal op_type 1
            # "it": mov rcx, rax (0x48 0x89 0xC1)
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x89 into text at text_len
            add text_len 1
            store it into text_len
            store 0xC1 into text at text_len
            add text_len 1
            store it into text_len
        end
        if equal op_type 2
            # mov rcx, [rbp+offset] = 0x48 0x8B 0x8D + disp32 LE
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x8B into text at text_len
            add text_len 1
            store it into text_len
            store 0x8D into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        end

        # ── Restore A, emit: load A into rax ──
        store a_type into op_type
        store a_val into op_val
        store a_off into op_off

        if equal op_type 0
            # mov eax, imm32 (0xB8 + imm32 LE)
            store 0xB8 into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_val 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        end
        if equal op_type 1
            # "it" — rax already has the value, nop
        end
        if equal op_type 2
            # mov rax, [rbp+offset] = 0x48 0x8B 0x85 + disp32 LE
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x8B into text at text_len
            add text_len 1
            store it into text_len
            store 0x85 into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        end

        # ── Emit the operation ──
        store cf_patch into temp
        if equal temp 2
            # add rax, rcx: 0x48 0x01 0xC8
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x01 into text at text_len
            add text_len 1
            store it into text_len
            store 0xC8 into text at text_len
            add text_len 1
            store it into text_len
        end
        if equal temp 3
            # sub rax, rcx: 0x48 0x29 0xC8
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x29 into text at text_len
            add text_len 1
            store it into text_len
            store 0xC8 into text at text_len
            add text_len 1
            store it into text_len
        end
        if equal temp 4
            # imul rax, rcx: 0x48 0x0F 0xAF 0xC1
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x0F into text at text_len
            add text_len 1
            store it into text_len
            store 0xAF into text at text_len
            add text_len 1
            store it into text_len
            store 0xC1 into text at text_len
            add text_len 1
            store it into text_len
        end
        if equal temp 5
            # cqo; idiv rcx: 0x48 0x99 0x48 0xF7 0xF9
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x99 into text at text_len
            add text_len 1
            store it into text_len
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0xF7 into text at text_len
            add text_len 1
            store it into text_len
            store 0xF9 into text at text_len
            add text_len 1
            store it into text_len
        end
    end

    # ── Variable declaration: a(17) or global(59) ───────────
    store 0 into matched
    if equal temp 17
        store 1 into matched
    end
    if equal temp 59
        store 1 into matched
    end
    if compare matched 0
        add tok_idx 1
        store it into tok_idx
        load from tok_type at tok_idx
        store it into temp2

        # Check if next token is a type noun (53-58)
        store 0 into temp3
        if equal temp2 53
            store 1 into temp3
        end
        if equal temp2 54
            store 1 into temp3
        end
        if equal temp2 55
            store 1 into temp3
        end
        if equal temp2 56
            store 1 into temp3
        end
        if equal temp2 57
            store 1 into temp3
        end
        if equal temp2 58
            store 1 into temp3
        end

        if compare temp3 0
            # Type noun present: a/global TYPE NAME [SIZE]
            store temp2 into temp4
            add tok_idx 1
            store it into tok_idx
            # tok_idx now points at NAME
            load from tok_start at tok_idx
            store it into var_name_start at var_count
            load from tok_len at tok_idx
            store it into var_name_len at var_count

            # Check if next token is a size literal
            add tok_idx 1
            store it into temp2
            store 8 into temp3
            if compare temp2 tok_count
                load from tok_type at temp2
                if equal it 50
                    load from tok_value at temp2
                    store it into temp3
                    store temp2 into tok_idx
                    # For long type, size is count * 8
                    if equal temp4 54
                        multiply temp3 8
                        store it into temp3
                    end
                else
                    subtract tok_idx 1
                    store it into tok_idx
                end
            else
                subtract tok_idx 1
                store it into tok_idx
            end

            # Allocate stack space
            if equal temp4 53
                store 1 into var_type at var_count
            else
                store 0 into var_type at var_count
            end
            add vreg_total_size temp3
            store it into vreg_total_size
            subtract 0 vreg_total_size
            store it into var_offset at var_count
            add var_count 1
            store it into var_count
        else
            # Simple variable: a/global NAME (8 bytes)
            load from tok_start at tok_idx
            store it into var_name_start at var_count
            load from tok_len at tok_idx
            store it into var_name_len at var_count
            store 0 into var_type at var_count
            add vreg_total_size 8
            store it into vreg_total_size
            subtract 0 vreg_total_size
            store it into var_offset at var_count
            add var_count 1
            store it into var_count
        end
    end

    # ── Store: store(6) V into X [at I] ──────────────────────
    if equal temp 6
        # Advance to V
        add tok_idx 1
        store it into tok_idx

        # ── Resolve operand V (save into a_type/a_val/a_off) ──
        load from tok_type at tok_idx
        store it into op_type
        store 0 into op_val
        store 0 into op_off
        if equal op_type 50
            load from tok_value at tok_idx
            store it into op_val
            store 0 into op_type
        end
        if equal op_type 22
            store 1 into op_type
        end
        if equal op_type 52
            store 2 into op_type
            load from tok_start at tok_idx
            store it into lookup_src
            load from tok_len at tok_idx
            store it into lookup_len
            store 0 into lookup_i
            subtract 0 1
            store it into lookup_result
            while compare lookup_i var_count
                load from var_name_len at lookup_i
                store it into lookup_cmp_len
                if equal lookup_len lookup_cmp_len
                    load from var_name_start at lookup_i
                    store it into lookup_cmp_start
                    store 1 into lookup_match
                    store 0 into lookup_j
                    while compare lookup_j lookup_len
                        add lookup_src lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_a
                        add lookup_cmp_start lookup_j
                        store it into lookup_k
                        load from input at lookup_k
                        store it into lookup_b
                        if compare lookup_a lookup_b
                            store 0 into lookup_match
                        end
                        add lookup_j 1
                        store it into lookup_j
                    end
                    if compare lookup_match 0
                        store lookup_i into lookup_result
                    end
                end
                add lookup_i 1
                store it into lookup_i
            end
            load from var_offset at lookup_result
            store it into op_off
        end
        # Save V resolved info
        store op_type into a_type
        store op_val into a_val
        store op_off into a_off

        # Skip "into" keyword
        add tok_idx 1
        store it into tok_idx

        # Advance to X (destination variable)
        add tok_idx 1
        store it into tok_idx

        # ── Look up variable X ──
        load from tok_start at tok_idx
        store it into lookup_src
        load from tok_len at tok_idx
        store it into lookup_len
        store 0 into lookup_i
        subtract 0 1
        store it into lookup_result
        while compare lookup_i var_count
            load from var_name_len at lookup_i
            store it into lookup_cmp_len
            if equal lookup_len lookup_cmp_len
                load from var_name_start at lookup_i
                store it into lookup_cmp_start
                store 1 into lookup_match
                store 0 into lookup_j
                while compare lookup_j lookup_len
                    add lookup_src lookup_j
                    store it into lookup_k
                    load from input at lookup_k
                    store it into lookup_a
                    add lookup_cmp_start lookup_j
                    store it into lookup_k
                    load from input at lookup_k
                    store it into lookup_b
                    if compare lookup_a lookup_b
                        store 0 into lookup_match
                    end
                    add lookup_j 1
                    store it into lookup_j
                end
                if compare lookup_match 0
                    store lookup_i into lookup_result
                end
            end
            add lookup_i 1
            store it into lookup_i
        end
        load from var_offset at lookup_result
        store it into x_off
        store lookup_result into x_idx

        # ── Check for "at" (indexed store) ──
        add tok_idx 1
        store it into temp2
        store 0 into temp4
        if compare temp2 tok_count
            load from tok_type at temp2
            if equal it 21
                store 1 into temp4
            end
        end

        if equal temp4 0
            # ── Simple store: store V into X ──
            # tok_idx still points at X (the peek didn't change it)

            # Restore V info
            store a_type into op_type
            store a_val into op_val
            store a_off into op_off

            # Emit: load V into rcx
            if equal op_type 0
                store 0xB9 into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 1
                # "it": mov rcx, rax
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x89 into text at text_len
                add text_len 1
                store it into text_len
                store 0xC1 into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 2
                # mov rcx, [rbp+offset]
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x8B into text at text_len
                add text_len 1
                store it into text_len
                store 0x8D into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end

            # Emit: mov [rbp+X_offset], rcx = 0x48 0x89 0x8D + disp32 LE
            store x_off into op_off
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x89 into text at text_len
            add text_len 1
            store it into text_len
            store 0x8D into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF00
            divide it 256
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF0000
            divide it 65536
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF000000
            divide it 16777216
            store it into text at text_len
            add text_len 1
            store it into text_len
        else
            # ── Indexed store: store V into X at I ──
            # temp2 points at "at" token, tok_idx at X
            # op_off = X's stack offset, temp3 = X's var index
            store temp2 into tok_idx

            # Advance past "at" to I (index operand)
            add tok_idx 1
            store it into tok_idx

            # Step 1: Emit load V into rdx (a_off has V's offset, x_off has X's offset)
            store a_type into op_type
            store a_val into op_val
            store a_off into op_off

            if equal op_type 0
                # mov edx, imm32: 0xBA + imm32 LE
                store 0xBA into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 1
                # "it": mov rdx, rax = 0x48 0x89 0xC2
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x89 into text at text_len
                add text_len 1
                store it into text_len
                store 0xC2 into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 2
                # mov rdx, [rbp+V_offset]: 0x48 0x8B 0x95 + disp32 LE
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x8B into text at text_len
                add text_len 1
                store it into text_len
                store 0x95 into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end

            # Step 2: Resolve I into rcx
            load from tok_type at tok_idx
            store it into op_type
            store 0 into op_val
            store 0 into op_off

            if equal op_type 50
                load from tok_value at tok_idx
                store it into op_val
                store 0 into op_type
            end
            if equal op_type 22
                store 1 into op_type
            end
            if equal op_type 52
                store 2 into op_type
                load from tok_start at tok_idx
                store it into lookup_src
                load from tok_len at tok_idx
                store it into lookup_len
                store 0 into lookup_i
                subtract 0 1
                store it into lookup_result
                while compare lookup_i var_count
                    load from var_name_len at lookup_i
                    store it into lookup_cmp_len
                    if equal lookup_len lookup_cmp_len
                        load from var_name_start at lookup_i
                        store it into lookup_cmp_start
                        store 1 into lookup_match
                        store 0 into lookup_j
                        while compare lookup_j lookup_len
                            add lookup_src lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_a
                            add lookup_cmp_start lookup_j
                            store it into lookup_k
                            load from input at lookup_k
                            store it into lookup_b
                            if compare lookup_a lookup_b
                                store 0 into lookup_match
                            end
                            add lookup_j 1
                            store it into lookup_j
                        end
                        if compare lookup_match 0
                            store lookup_i into lookup_result
                        end
                    end
                    add lookup_i 1
                    store it into lookup_i
                end
                load from var_offset at lookup_result
                store it into op_off
            end

            # Emit: load I into rcx
            if equal op_type 0
                store 0xB9 into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_val 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 1
                # "it": mov rcx, rax
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x89 into text at text_len
                add text_len 1
                store it into text_len
                store 0xC1 into text at text_len
                add text_len 1
                store it into text_len
            end
            if equal op_type 2
                # mov rcx, [rbp+offset]
                store 0x48 into text at text_len
                add text_len 1
                store it into text_len
                store 0x8B into text at text_len
                add text_len 1
                store it into text_len
                store 0x8D into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF00
                divide it 256
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF0000
                divide it 65536
                store it into text at text_len
                add text_len 1
                store it into text_len
                bitand op_off 0xFF000000
                divide it 16777216
                store it into text at text_len
                add text_len 1
                store it into text_len
            end

            # Step 3: Emit lea rax, [rbp+X_offset]: 0x48 0x8D 0x85 + disp32 LE
            store x_off into op_off
            store 0x48 into text at text_len
            add text_len 1
            store it into text_len
            store 0x8D into text at text_len
            add text_len 1
            store it into text_len
            store 0x85 into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF
            store it into text at text_len
            add text_len 1
            store it into text_len
            bitand op_off 0xFF00
            divide it 256
