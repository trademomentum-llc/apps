    return 0

###############################################################################
# Section 5: IRQ Common Handler and Dispatch
###############################################################################

###############################################################################
# Function: irq_common_handler
# -----------------------------------------------------------------------------
# Common entry point for all hardware IRQs (vectors 32-47).
# In a real kernel, an assembly stub would push the vector number and
# jump here. We dispatch based on the vector to the specific driver handler.
###############################################################################

irq_common_handler
    a vector_num

    # In real implementation, vector_num is pushed by assembly stub
    # Here we model the dispatch conceptually
    # The actual vector would be determined from the interrupt context
    print "[irq] common handler dispatch"
    return 0

###############################################################################
# Function: irq_dispatch
# -----------------------------------------------------------------------------
# Dispatch an IRQ to the appropriate device driver handler.
#
# irq_num: the hardware IRQ number (0-15), NOT the vector number
#
# This is called by the low-level assembly IRQ stubs after saving context.
###############################################################################

irq_dispatch
    a irq_num

    store it into irq_num

    # IRQ0: PIT timer
    if equal irq_num 0
        call pit_handler
        return 0
    end

    # IRQ1: PS/2 keyboard
    if equal irq_num 1
        call keyboard_handler
        return 0
    end

    # IRQ2: cascade (slave PIC) — should not fire directly
    if equal irq_num 2
        print "[irq] cascade signal (IRQ2)"
        call pic_eoi 2
        return 0
    end

    # IRQ3-7: unhandled serial/parallel ports
    if less irq_num 8
        print "[irq] unhandled IRQ "
        print irq_num
        call pic_eoi irq_num
        return 0
    end

    # IRQ8-15: slave PIC interrupts
    if less irq_num 16
        print "[irq] slave IRQ "
        print irq_num
        call pic_eoi irq_num
        return 0
    end

    # Invalid IRQ number
    print "[irq] invalid IRQ number: "
    print irq_num
    return 0

###############################################################################
# Section 6: System Call Entry Stub
###############################################################################

###############################################################################
# Function: syscall_entry_point
# -----------------------------------------------------------------------------
# Assembly stub for int 0x80 system calls.
# In a real kernel, this stub would:
#   1. Save all user registers on the kernel stack
#   2. Load kernel segment selectors
#   3. Call syscall_handler with register arguments
#   4. Restore registers
#   5. iretq back to user mode
#
# Here we model the concept since Jasterish abstracts the assembly layer.
###############################################################################

syscall_entry_point
    # In real implementation:
    #   swapgs (if using GS base for per-CPU data)
    #   push all registers
    #   call syscall_handler
    #   pop all registers
    #   iretq

    # For Jasterish, we delegate to the high-level handler
    call syscall_handler
    return 0

###############################################################################
# Section 7: IDT Utility Functions
###############################################################################

###############################################################################
# Function: idt_disable_interrupts
# -----------------------------------------------------------------------------
# Disable interrupts (CLI).
###############################################################################

idt_disable_interrupts
    inline "cli"
    return 0

###############################################################################
# Function: idt_enable_interrupts
# -----------------------------------------------------------------------------
# Enable interrupts (STI).
###############################################################################

idt_enable_interrupts
    inline "sti"
    return 0

###############################################################################
# End of idt.jstr
###############################################################################
