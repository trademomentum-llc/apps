# Handler for vector 6: invalid opcode.
###############################################################################

exception_invalid_opcode
    print ""
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print "!! EXCEPTION: Invalid Opcode (vector 6)"
    print "!!"
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print ""
    call panic "invalid opcode"
