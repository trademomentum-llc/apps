###############################################################################
# Function: exception_device_na
# -----------------------------------------------------------------------------
# Handler for vector 7: device not available.
###############################################################################

exception_device_na
    print "[exception] Device not available (vector 7)"
    call panic "device not available"
    return 0

###############################################################################
# Function: exception_double_fault
# -----------------------------------------------------------------------------
# Handler for vector 8: double fault.
# This is a critical error - the CPU faulted while handling a fault.
###############################################################################

exception_double_fault
    print ""
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print "!! EXCEPTION: DOUBLE FAULT (vector 8)"
    print "!! The system is in an unrecoverable state."
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print ""
    # Double fault is fatal - halt forever
    inline "cli"
    inline "hlt"
    return 0

###############################################################################
# Function: exception_invalid_tss
# -----------------------------------------------------------------------------
# Handler for vector 10: invalid TSS.
###############################################################################

exception_invalid_tss
    print "[exception] Invalid TSS (vector 10)"
    call panic "invalid TSS"
    return 0

###############################################################################
# Function: exception_segment_np
# -----------------------------------------------------------------------------
# Handler for vector 11: segment not present.
###############################################################################

exception_segment_np
    print "[exception] Segment not present (vector 11)"
    call panic "segment not present"
    return 0

###############################################################################
# Function: exception_stack_fault
# -----------------------------------------------------------------------------
# Handler for vector 12: stack-segment fault.
###############################################################################

exception_stack_fault
    print "[exception] Stack fault (vector 12)"
    call panic "stack fault"
    return 0

###############################################################################
# Function: exception_gpf
# -----------------------------------------------------------------------------
# Handler for vector 13: general protection fault.
###############################################################################

exception_gpf
    print ""
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print "!! EXCEPTION: General Protection Fault (vector 13)"
    print "!!"
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print ""
    call panic "general protection fault"
    return 0

###############################################################################
# Function: exception_page_fault
# -----------------------------------------------------------------------------
# Handler for vector 14: page fault.
# Reads CR2 to get the faulting address and prints diagnostic info.
###############################################################################

exception_page_fault
    a fault_addr
    a error_code
    a pte
    a old_phys
    a new_phys
    a pte_flags
    a is_cow
    a is_write

    # CR2 holds the virtual address that caused the page fault
    inline "mov rax, cr2"
    store register rax into fault_addr

    # Read the error code from the stack. In x86-64, the CPU pushes
    # the error code after RIP/CS/RFLAGS (and SS/RSP if cross-privilege).
    # After the function prologue, the error code is at [rbp+8].
    inline "mov rax, [rbp+8]"
    store register rax into error_code

    # Resolve the PTE for the faulting address
    call vmm_resolve_pte fault_addr
    store it into pte

    # Check if this is a COW page
    bitwise_and pte PAGE_COW
    store it into is_cow

    # The error code bit 1 indicates a write fault
    bitwise_and error_code 2
    store it into is_write

    load is_cow
    load 0
    if not equal it it
        load is_write
        load 0
        if not equal it it
            # This is a write fault on a COW page -- copy the page

        # Extract the old physical page address
        bitwise_and pte PAGE_FLAGS_MASK
        store it into old_phys

        # Allocate a new physical page
        call pmm_alloc
        store it into new_phys

        load new_phys
        load 0
        if equal it it
            print ""
            print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
            print "!! EXCEPTION: Page Fault (vector 14)"
            print "!! COW copy failed: out of memory"
            print "!! Faulting address: "
            load fault_addr
            call serial_print_hex
            print ""
            print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
            print ""
            call panic "COW page fault: out of memory"
            return 0
        end

        # Copy the old page contents to the new page.
        # Since physical memory below 1GB is identity-mapped,
        # we can use memcpy directly on physical addresses.
        call memcpy new_phys old_phys PAGE_SIZE

        # Build new PTE: new physical address | PRESENT | WRITABLE | USER
        # Clear COW flag so this process owns the writable copy.
        bitwise_and new_phys PAGE_FLAGS_MASK
        store it into pte_flags
        bitwise_or pte_flags PAGE_PRESENT
        store it into pte_flags
        bitwise_or pte_flags PAGE_WRITABLE
        store it into pte_flags
        bitwise_or pte_flags PAGE_USER
        store it into pte_flags

        # Update the page table entry
        call vmm_update_pte fault_addr pte_flags

        print "[COW] Copied page for address "
        load fault_addr
        call serial_print_hex
        print " old_phys="
        load old_phys
        call serial_print_hex
        print " new_phys="
        load new_phys
        call serial_print_hex

        # Skip error code on stack and return via iretq.
        # In x86-64, the CPU always pushes SS:RSP for interrupts,
        # so the full frame is present after skipping the error code.
        inline "leave"
        inline "add rsp, 8"
        inline "iretq"

        # unreachable
        return 0
        end
    end

    # Not a COW fault -- print diagnostics and panic
    print ""
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print "!! EXCEPTION: Page Fault (vector 14)"
    print "!!"

    print "!! Faulting address: "
    load fault_addr
    call serial_print_hex
    print ""
    print "!! Error code: "
    load error_code
    call serial_print_hex
    print ""
    print "!! PTE: "
    load pte
    call serial_print_hex
    print ""
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print ""

    call panic "page fault"
    return 0

