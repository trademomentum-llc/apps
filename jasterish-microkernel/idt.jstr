###############################################################################

exception_machine_check
    print ""
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print "!! EXCEPTION: Machine Check (vector 18)"
    print "!! Hardware failure detected."
    print "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    print ""
    inline "cli"
    inline "hlt"
    return 0

###############################################################################
# Function: exception_simd_error
